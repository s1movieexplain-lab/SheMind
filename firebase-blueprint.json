{
  "entities": {
    "UserProgress": {
      "title": "User Progress",
      "description": "Stores user's progress, bookmarks, and learning goals.",
      "type": "object",
      "properties": {
        "completedLessons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "bookmarks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "goals": {
          "type": "array",
          "items": { "type": "string" }
        },
        "streak": {
          "type": "number"
        },
        "lastActive": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["completedLessons", "bookmarks", "goals", "streak"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProgress",
      "description": "Individual user progress and preferences."
    }
  }
}
